{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Day13LogRecord",
  "type": "object",
  "additionalProperties": true,
  "required": ["ts", "level", "service", "event", "correlation_id"],
  "properties": {
    "ts": {"type": "string", "format": "date-time", "minLength": 1},
    "level": {"type": "string", "enum": ["debug", "info", "warning", "error", "critical"]},
    "service": {"type": "string", "minLength": 1},
    "event": {"type": "string", "minLength": 1},
    "correlation_id": {"type": "string", "minLength": 1},
    "env": {"type": ["string", "null"]},
    "user_id_hash": {"type": ["string", "null"]},
    "session_id": {"type": ["string", "null"]},
    "feature": {"type": ["string", "null"]},
    "model": {"type": ["string", "null"]},
    "latency_ms": {"type": ["integer", "null"]},
    "tokens_in": {"type": ["integer", "null"]},
    "tokens_out": {"type": ["integer", "null"]},
    "cost_usd": {"type": ["number", "null"]},
    "error_type": {"type": ["string", "null"]},
    "tool_name": {"type": ["string", "null"]},
    "payload": {"type": ["object", "null"]},
    "exception": {"type": ["string", "null"]}
  }
}
